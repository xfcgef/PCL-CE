    <sys:String x:Key="Setup.Misc.Network.Proxy.UntrustedWarning">Do not enter untrusted proxy addresses</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.InvalidWarning">Incorrect proxy server addresses will cause network connection failures. Network issues caused by proxy usage will not be handled.&#x0a;Do not enter untrusted proxy server addresses, as this may lead to account information leakage or even account theft.</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.Username">Account</sys:String>
