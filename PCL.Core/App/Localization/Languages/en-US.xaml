    <sys:String x:Key="Setup.Misc.Network.DoH">Use DoH for address resolution</sys:String>
    <sys:String x:Key="Setup.Misc.Network.DoH.ToolTip">Using DoH for address resolution can provide better IP results and improve the launcher's network access. If you have deployed a DoH resolution service, you can disable this feature.</sys:String>
    <sys:String x:Key="Setup.Misc.Network.HttpProxy">HTTP proxy</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.None">No proxy</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.System">Use system proxy</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.Custom">Custom proxy</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.UntrustedWarning">Do not enter untrusted proxy addresses</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.InvalidWarning">Incorrect proxy server addresses will cause network connection failures. Network issues caused by proxy usage will not be handled.&#x0a;Do not enter untrusted proxy server addresses, as this may lead to account information leakage or even account theft.</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.Username">Account</sys:String>
