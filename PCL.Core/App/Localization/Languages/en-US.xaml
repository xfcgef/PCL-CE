    <!-- Setup.Update -->
    <sys:String x:Key="Setup.Update.Channel.Title">Update channel</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Release">Release</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Release.ToolTip">A relatively stable version that only receives bug fixes and some built-in resource updates. Suitable for most users.</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Beta">Beta</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Beta.ToolTip">Potentially unstable beta versions for early feature testing. Suitable for users who want to help test and have some technical ability.</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev">Dev</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.ToolTip">Potentially highly unstable development versions built directly from the latest source code. Suitable for highly technical users.&#x0a;Good internet connectivity may be required to download updates from this channel.</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Beta.Warning.Message">You are switching the launcher update channel to Beta.&#x0a;Beta versions provide previews of upcoming updates, but may include insufficiently tested features and have reduced stability.&#x0a;&#x0a;After upgrading to Beta, you will need to wait for the next Release version or manually re-download the launcher to switch back to Release.&#x0a;This option is only recommended for users with some basic knowledge and ability. If you are creating a modpack, please use the Release version!</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Common.Warning.Title">Before continuing...</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Common.Warning.Confirm">I understand</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.Warning.Message">You are switching the launcher update channel to Dev.&#x0a;This channel provides early access to development builds from the latest code, but may be extremely unstable or even fail to launch.&#x0a;&#x0a;After upgrading to Dev, you can only manually re-download the launcher to switch back to Release or Beta.&#x0a;This option is only recommended for advanced users. If you are creating a modpack, please use the Release version!</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.FinalConfirm.Title">Final confirmation</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.FinalConfirm.Message">Are you sure you want to switch to the Dev channel?&#x0a;Dev versions may have serious issues or even fail to launch!&#x0a;&#x0a;After upgrading to Dev, you will not be able to switch back to any other update channel without manually re-downloading the launcher.&#x0a;&#x0a;This option is only recommended for advanced users. If you are creating a modpack, please use the Release version!&#x0a;Please enter &quot;{0}&quot; to confirm.</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.FinalConfirm.Submit">Submit</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.FinalConfirm.ExpectedInput">I confirm switching to this branch and am aware of the risks</sys:String>
    <sys:String x:Key="Setup.Update.Channel.Dev.FinalConfirm.WrongInput">The content you entered is incorrect...</sys:String>
    <sys:String x:Key="Setup.Update.Auto.Title">Auto update settings</sys:String>
    <sys:String x:Key="Setup.Update.Auto.DownloadAndInstall">Automatically download and install updates</sys:String>
    <sys:String x:Key="Setup.Update.Auto.DownloadAndInstall.ToolTip">The launcher will automatically check for and download available updates, and install them after closing.</sys:String>
    <sys:String x:Key="Setup.Update.Auto.DownloadAndNotify">Automatically download and prompt for update</sys:String>
    <sys:String x:Key="Setup.Update.Auto.DownloadAndNotify.ToolTip">The launcher will automatically check for and download available updates, then prompt you to install.</sys:String>
    <sys:String x:Key="Setup.Update.Auto.NotifyOnly">Prompt for update</sys:String>
    <sys:String x:Key="Setup.Update.Auto.NotifyOnly.ToolTip">The launcher will automatically check for available updates, then prompt you to download and install.</sys:String>
    <sys:String x:Key="Setup.Update.Auto.Disabled">Do not automatically check for updates (not recommended)</sys:String>
    <sys:String x:Key="Setup.Update.Auto.Disabled.ToolTip">Disable automatic update checking. This may prevent you from receiving updates in a timely manner.</sys:String>
    <sys:String x:Key="Setup.Update.MirrorChyanCdk.Label">MirrorChyan CDK</sys:String>
    <sys:String x:Key="Setup.Update.MirrorChyanCdk.ToolTip">MirrorChyan (mirrorchyan.com) is a paid third-party application distribution platform that provides high-speed download sources in China.&#x0a;This is an optional service. Leaving the CDK blank does not affect normal use or updates.&#x0a;If you have a MirrorChyan CDK, you can provide it to PCL CE, and the launcher will prioritize its high-speed download source for software updates. This can also help reduce pressure on the community update server...</sys:String>
    <sys:String x:Key="Setup.Update.MirrorChyanCdk.Get">Get CDK</sys:String>
    <sys:String x:Key="Setup.Update.Install">Download and install</sys:String>
    <sys:String x:Key="Setup.Update.RestartInstall">Restart to install</sys:String>
