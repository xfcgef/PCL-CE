    <!-- Setup.Misc -->
    <sys:String x:Key="Setup.Misc.System.Title">System</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement">Launcher announcements</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement.All">Show all announcements</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement.All.ToolTip">Show all announcements, including launcher feature surveys, events, and more.</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement.ImportantOnly">Show announcements only when important</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement.Disabled">Disable all announcements</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement.Disabled.Warning.Message">If you choose this option, you will not receive relevant notifications even when serious issues occur in the future.&#x0a;For example, if a critical bug is found in a certain game version, you may miss the notification and face unpredictable consequences.&#x0a;&#x0a;In general, choosing &quot;Show announcements only when important&quot; should keep you mostly undisturbed.&#x0a;Unless you are creating a server modpack or frequently update the launcher manually, this option is strongly discouraged!</sys:String>
    <sys:String x:Key="Setup.Misc.System.Announcement.Disabled.Warning.Confirm">I know what I am doing</sys:String>
    <sys:String x:Key="Setup.Misc.System.MaxFps">Maximum animation FPS</sys:String>
    <sys:String x:Key="Setup.Misc.System.MaxFps.ToolTip">If you have disabled hardware acceleration, it is recommended to lower the max animation FPS to prevent excessive resource usage</sys:String>
    <sys:String x:Key="Setup.Misc.System.MaxLogLines">Real-time log lines</sys:String>
    <sys:String x:Key="Setup.Misc.System.MaxLogLines.ToolTip">Maximum number of lines displayed in the real-time log feature. Old logs are automatically deleted when exceeded.</sys:String>
    <sys:String x:Key="Setup.Misc.System.DisableHardwareAcceleration">Disable hardware acceleration</sys:String>
    <sys:String x:Key="Setup.Misc.System.Telemetry">Enable telemetry data collection</sys:String>
    <sys:String x:Key="Setup.Misc.System.Telemetry.ToolTip">When enabled, the launcher will collect and report errors and device environment information. This helps developers fix potential issues and better plan and develop the launcher.&#x0a;The following information will be collected: launcher errors, launcher version information and identifier, Windows system version and architecture, installed physical memory size, NAT and IPv6 support status, and whether official PCL, HMCL, or BakaXL have been used.&#x0a;&#x0a;This data is not associated with you, and we will never sell it to any third party. Not enabling this will not affect other features, but may affect developers' ability to fix potential bugs.&#x0a;&#x0a;This change will take effect after restarting the launcher.</sys:String>
    <sys:String x:Key="Setup.Misc.System.ExportSettings">Export settings</sys:String>
    <sys:String x:Key="Setup.Misc.System.ImportSettings">Import settings</sys:String>
