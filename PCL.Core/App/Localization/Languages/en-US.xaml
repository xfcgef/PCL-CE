    <sys:String x:Key="Setup.Misc.Network.DoH">Use DoH for address resolution</sys:String>
    <sys:String x:Key="Setup.Misc.Network.DoH.ToolTip">Using DoH for address resolution can provide better IP results and improve the launcher's network access. If you have deployed a DoH resolution service, you can disable this feature.</sys:String>
    <sys:String x:Key="Setup.Misc.Network.HttpProxy">HTTP proxy</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.None">No proxy</sys:String>
    <sys:String x:Key="Setup.Misc.Network.Proxy.System">Use system proxy</sys:String>
